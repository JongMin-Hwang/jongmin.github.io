<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>비즈니스 PPT 디자인 솔루션</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="stylesheet" as="style" crossorigin
  href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />
<style>
  :root{
    --bg: #0b0d0c;
    --bg-soft: #121412;
    --card: #171917;
    --line: #2a2d2a;
    --text: #f2f3f1;
    --text-dim: #a9aca8;
    --accent: #a6ff2f;
    --accent-dim: #7ec924;
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    font-family:'Pretendard', -apple-system, BlinkMacSystemFont, 'Malgun Gothic', sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.5;
  }
  img{ max-width:100%; display:block; }
  a{ color:inherit; text-decoration:none; }
  ul{ list-style:none; }
  .wrap{ max-width:1160px; margin:0 auto; padding:0 24px; }

  /* ---------- Buttons ---------- */
  .btn{
    display:inline-flex; align-items:center; justify-content:center;
    padding:14px 28px; border-radius:6px; font-weight:700; font-size:15px;
    cursor:pointer; border:none; transition:transform .15s ease, opacity .15s ease;
  }
  .btn:hover{ transform:translateY(-2px); }
  .btn-accent{ background:var(--accent); color:#0b0d0c; }
  .btn-accent:hover{ background:var(--accent-dim); }
  .btn-outline{ background:transparent; color:var(--text); border:1px solid var(--line); }
  .btn-sm{ padding:10px 18px; font-size:13px; }
  .btn-block{ width:100%; }

  /* ---------- Image Placeholder ---------- */
  .frame{
    background:
      repeating-linear-gradient(45deg, #1d1f1d, #1d1f1d 10px, #222422 10px, #222422 20px);
    border:1px dashed #3a3d3a;
    border-radius:10px;
    display:flex; align-items:center; justify-content:center;
    color:#787c78; font-size:13px; text-align:center; padding:16px;
    min-height:180px;
  }
  .frame span{ opacity:.85; }

  /* ---------- Top bar ---------- */
  .topbar{
    background:linear-gradient(90deg,#ff3b7f,#ff7a3b);
    text-align:center; font-size:12px; padding:8px 12px; color:#1a1a1a; font-weight:600;
  }

  /* ---------- Header ---------- */
  header{
    background:var(--bg); border-bottom:1px solid var(--line);
    position:sticky; top:0; z-index:50;
  }
  .nav{ display:grid; grid-template-columns:1fr auto 1fr; align-items:center; padding:16px 0; }
  .nav-menu{ display:flex; gap:32px; font-size:14px; color:var(--text-dim); justify-content:center; grid-column:2; }
  .nav-cta{ justify-self:end; grid-column:3; }
  .nav-menu a:hover{ color:var(--text); }
  .nav-cta{ display:flex; gap:10px; }

  /* ---------- Hero ---------- */
  .hero{
    padding:90px 0 70px;
    background:
      radial-gradient(ellipse 60% 50% at 15% 0%, rgba(166,255,47,.08), transparent 60%);
    text-align:center;
  }
  .eyebrow{ color:var(--accent); font-size:14px; font-weight:600; margin-bottom:18px; }
  .hero h1{
    font-size:38px; font-weight:800; letter-spacing:-0.02em; line-height:1.35;
    margin-bottom:14px;
  }
  .hero .sub{
    font-size:18px; font-weight:600; color:var(--accent); line-height:1.6;
  }

  .hero-cards{
    display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-top:56px;
  }
  .hero-card{
    background:var(--card); border:1px solid var(--line); border-radius:14px;
    padding:24px; text-align:left;
  }
  .hero-card h3{ font-size:15px; font-weight:700; margin-bottom:16px; text-align:center; color:var(--text-dim);}
  .hero-card .btn{ width:100%; }
  .hero-media{ margin-bottom:20px; }
  .hero-media.single .frame{ min-height:220px; }
  .hero-media.split{ display:grid; grid-template-columns:1.3fr 1fr; gap:10px; height:220px; }
  .hero-media.split .frame:first-child{ min-height:auto; height:100%; }
  .hero-media.split .stack{ display:grid; grid-template-rows:1fr 1fr; gap:10px; height:100%; }
  .hero-media.split .stack .frame{ min-height:auto; height:100%; }

  /* ---------- Generic Section ---------- */
  section{ padding:90px 0; }
  .section-alt{ background:var(--bg-soft); }
  .center{ text-align:center; }
  .section-eyebrow{ color:var(--text-dim); font-size:14px; margin-bottom:14px; }
  .section-title{
    font-size:28px; font-weight:800; letter-spacing:-0.02em; margin-bottom:28px; line-height:1.5;
  }
  .section-title .accent{ color:var(--accent); }
  .section-sub{ font-size:20px; font-weight:700; margin:50px 0 32px; }
  .section-link{
    display:block; margin-top:28px; font-weight:700; text-decoration:underline;
    text-underline-offset:5px; color:var(--text);
  }
  .section-link + .btn{ margin-top:24px; }

  /* ---------- Card grid (6 cards) ---------- */
  .bento-jobs{
    display:grid; grid-template-columns:repeat(6,1fr); gap:16px; align-items:start;
  }
  .job-card{ text-align:left; }
  .job-card .frame{ margin-bottom:14px; }
  .job-card h4{ font-size:15px; font-weight:700; margin-bottom:6px; }
  .job-card p{ font-size:13px; color:var(--text-dim); }
  .job-card.c1{ grid-column:span 3; }
  .job-card.c1 .frame{ aspect-ratio:2/1; }
  .job-card.c2{ grid-column:span 3; }
  .job-card.c2 .frame{ aspect-ratio:2/1; }
  .job-card.c3{ grid-column:span 2; }
  .job-card.c3 .frame{ aspect-ratio:4/3; }
  .job-card.c4{ grid-column:span 2; }
  .job-card.c4 .frame{ aspect-ratio:4/3; }
  .job-card.c5{ grid-column:span 2; }
  .job-card.c5 .frame{ aspect-ratio:4/3; }
  .job-card.c6{ grid-column:span 6; }
  .job-card.c6 .frame{ aspect-ratio:21/6; }

  /* ---------- Trust / logos section ---------- */
  .trust{ display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start; }
  .trust-block{ margin-bottom:44px; }
  .trust-block h3{ font-size:20px; font-weight:800; margin-bottom:10px; }
  .trust-block h3 .accent{ color:var(--accent); }
  .trust-block p{ font-size:14px; color:var(--text-dim); line-height:1.8; }
  .trust-stats{ font-size:14px; color:var(--text-dim); line-height:2; margin-bottom:24px; }
  .trust-stats b{ color:var(--text); }
  .logo-mosaic{
    display:grid; grid-template-columns:repeat(4,1fr); gap:10px;
  }
  .logo-mosaic .frame{ min-height:80px; font-size:11px; padding:8px; }
  .logo-mosaic .frame.wide{ grid-column:span 2; }

  /* ---------- Reviews ---------- */
  .tabs{
    display:flex; gap:10px; justify-content:center; margin-bottom:36px; flex-wrap:wrap;
  }
  .tab{
    padding:10px 20px; border-radius:24px; border:1px solid var(--line);
    font-size:13px; color:var(--text-dim); cursor:pointer;
  }
  .tab.active{ background:var(--accent); color:#0b0d0c; border-color:var(--accent); font-weight:700; }
  .review-grid, .portfolio-strip{ display:flex; flex-direction:column; gap:16px; }
  .tile-row{ display:flex; gap:16px; }
  .tile-row .frame{ flex:1 1 0; min-height:0; }
  .tile-row.h-sm{ height:190px; }
  .tile-row.h-md{ height:230px; }
  .tile-row.h-lg{ height:270px; }

  /* ---------- Download form ---------- */
  .download-sec{ display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; }
  .download-sec h2{ font-size:30px; font-weight:800; line-height:1.4; margin-bottom:12px; }
  .download-sec .desc{ color:var(--text-dim); font-size:14px; margin-bottom:28px; }
  .form-field{
    width:100%; padding:14px 16px; margin-bottom:12px; border-radius:6px;
    border:1px solid var(--line); background:var(--card); color:var(--text); font-size:14px;
  }
  .form-note{ font-size:12px; color:var(--text-dim); margin-top:14px; line-height:1.8; }
  .download-sec .frame{ min-height:360px; border-radius:50%; aspect-ratio:1/1; }

  /* portfolio-strip layout merged into .review-grid, .portfolio-strip rule above */

  /* ---------- FAQ ---------- */
  .faq-list{ max-width:760px; margin:0 auto; }
  .faq-item{
    border-bottom:1px solid var(--line); padding:20px 0; cursor:pointer;
  }
  .faq-q{ display:flex; justify-content:space-between; align-items:center; font-size:15px; font-weight:600; }
  .faq-q .plus{ color:var(--accent); font-size:18px; }
  .faq-a{
    display:none; margin-top:14px; font-size:14px; color:var(--text-dim); line-height:1.8;
  }
  .faq-item.open .faq-a{ display:block; }
  .faq-more{ text-align:center; margin-top:28px; }

  /* ---------- Footer ---------- */
  footer{ border-top:1px solid var(--line); padding:56px 0 28px; background:var(--bg-soft); }
  .footer-grid{ display:grid; grid-template-columns:1.2fr 1fr 1fr; gap:32px; margin-bottom:36px; }
  .footer-brand{
    display:inline-block; font-size:20px; font-weight:800; letter-spacing:-0.01em;
    color:var(--accent); margin-bottom:14px;
  }
  .footer-grid h5{ font-size:13px; color:var(--text-dim); margin-bottom:14px; font-weight:700; }
  .footer-grid p, .footer-grid a{ font-size:13px; color:var(--text-dim); line-height:2; display:block; }
  .footer-sns{ display:flex; gap:10px; margin-top:14px; }
  .footer-sns .frame{ width:36px; height:36px; min-height:36px; border-radius:50%; }
  .footer-bottom{
    border-top:1px solid var(--line); padding-top:20px; font-size:12px; color:#6d706c;
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:8px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width:860px){
    .nav-menu{ display:none; }
    .hero h1{ font-size:28px; }
    .hero .sub{ font-size:15px; }
    .hero-cards{ grid-template-columns:1fr; }
    .hero-media.split{ grid-template-columns:1fr; height:auto; }
    .hero-media.split .stack{ grid-template-columns:1fr 1fr; grid-template-rows:none; height:100px; }
    .bento-jobs{ grid-template-columns:1fr 1fr; }
    .job-card.c1, .job-card.c2, .job-card.c3, .job-card.c4, .job-card.c5, .job-card.c6{
      grid-column:span 2;
    }
    .job-card .frame{ aspect-ratio:16/10 !important; }
    .trust{ grid-template-columns:1fr; }
    .logo-mosaic{ grid-template-columns:repeat(2,1fr); }
    .logo-mosaic .frame.wide{ grid-column:span 2; }
    .tile-row{ flex-direction:column; height:auto !important; }
    .tile-row .frame{ height:150px; flex:none; }
    .download-sec{ grid-template-columns:1fr; }
    .footer-grid{ grid-template-columns:1fr; }
  }
</style>
</head>
